{
  "name": "opencode-chat",
  "version": "0.0.1",
  "description": "OpenCode plugin that provides multi-instance coordination tools for chat and broadcast messaging between OpenCode instances",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "chat",
    "multi-agent",
    "coordination",
    "broadcast"
  ],
  "homepage": "https://github.com/whaaaley/opencode-chat#readme",
  "bugs": {
    "url": "https://github.com/whaaaley/opencode-chat/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whaaaley/opencode-chat.git"
  },
  "license": "MIT",
  "author": "Dustin Dowell",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/chat.js",
      "types": "./dist/chat.d.ts"
    }
  },
  "main": "./dist/chat.js",
  "types": "./dist/chat.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "fmt": "bun run dprint fmt",
    "prepublishOnly": "npm run build",
    "test": "bun test"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.1.12",
    "@opencode-ai/sdk": "latest",
    "@types/bun": "1.3.9",
    "dprint": "latest",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.13.7"
  }
}
