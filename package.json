{
  "name": "opencode-relay",
  "version": "0.0.9",
  "description": "OpenCode plugin for relaying messages between multiple AI agent instances",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "relay",
    "multi-agent",
    "coordination",
    "broadcast"
  ],
  "homepage": "https://github.com/whaaaley/opencode-relay#readme",
  "bugs": {
    "url": "https://github.com/whaaaley/opencode-relay/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whaaaley/opencode-relay.git"
  },
  "license": "MIT",
  "author": "Dustin Dowell",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/relay.js",
      "types": "./dist/relay.d.ts"
    }
  },
  "main": "./dist/relay.js",
  "types": "./dist/relay.d.ts",
  "files": [
    "dist/",
    "instructions/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "fmt": "bun run dprint fmt",
    "prepublishOnly": "npm run build",
    "test": "bun test"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.1.12",
    "@types/bun": "1.3.9",
    "dprint": "latest",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.13.7"
  }
}
